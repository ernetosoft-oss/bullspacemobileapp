{
  "expo": {
    "name": "BullsPlace",
    "slug": "backtest-mobile-app",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.earneto.backtest",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.earneto.backtest",
      "versionCode": 1,
      "permissions": [
        "android.permission.INTERNET"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2196F3"
      },
      "jsEngine": "hermes"
    },
    "extra": {
      "eas": {
        "projectId": "35ae795c-63ef-432f-a8da-5f6f229a465e"
      }
    },
    "owner": "ernetosoft"
  }
}
